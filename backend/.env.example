APP_NAME=Personal Health Platform API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_AUTO_CREATE_TABLES=true
APP_DEBUG=false
LOG_LEVEL=INFO
TRUSTED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/personal_health
JWT_SECRET_KEY=replace_me_in_prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=personal-health-docs
S3_REGION=us-east-1
STORAGE_BACKEND=s3
LOCAL_STORAGE_ROOT=./uploads

MAX_UPLOAD_MB=10
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg
ALLOWED_FILE_EXTENSIONS=pdf,png,jpg,jpeg
MAX_UPLOAD_FILENAME_LENGTH=200

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

OCR_LANGUAGE=eng
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

ORCHESTRATOR_PROFILE_PATH=runtime/agent_orchestrator/project_profile.json
ORCHESTRATOR_SCHEDULER_AUTOSTART=false
