# Frontend
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ERROR_TRACKING_DSN=

# Backend
APP_NAME=Personal Health Platform API
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_AUTO_CREATE_TABLES=false
APP_DEBUG=false
LOG_LEVEL=INFO
TRUSTED_HOSTS=api.example.com

DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/personal_health
JWT_SECRET_KEY=replace_with_secure_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY=replace_me
S3_SECRET_KEY=replace_me
S3_BUCKET=personal-health-docs
S3_REGION=us-east-1
STORAGE_BACKEND=s3
LOCAL_STORAGE_ROOT=./uploads

MAX_UPLOAD_MB=10
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg
ALLOWED_FILE_EXTENSIONS=pdf,png,jpg,jpeg
MAX_UPLOAD_FILENAME_LENGTH=200

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OCR_LANGUAGE=eng

CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept
CORS_ALLOW_CREDENTIALS=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

SENTRY_DSN=
SENTRY_ENVIRONMENT=production

ORCHESTRATOR_PROFILE_PATH=runtime/agent_orchestrator/project_profile.json
ORCHESTRATOR_SCHEDULER_AUTOSTART=false
